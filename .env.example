# Contentful credentials
# Get from: app.contentful.com → Space Settings → API Keys
CONTENTFUL_SPACE_ID=your_space_id_here
CONTENTFUL_ACCESS_TOKEN=your_content_delivery_api_token_here
CONTENTFUL_PREVIEW_ACCESS_TOKEN=your_content_preview_api_token_here

# Shopify — pre-configured to use hydrogen-preview.myshopify.com (public demo)
# No Shopify account needed for local development
# To use your own store: update hydrogen.config.js storeDomain + storefrontToken
